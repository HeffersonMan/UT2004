Announcer=(ClassName=UnrealGame.ClassicAnnouncer,PackageName=AnnouncerMain,FallbackPackage=AnnouncerMale2K4,EnglishOnly=1,FriendlyName=UnrealGame.ClassicAnnouncer.AnnouncerName,FallbackName="UT2003")
